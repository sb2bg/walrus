import "std/math";

let eps = 0.000001;

println(math.abs(math.pi() - 3.141592653589793) < eps);
println(math.abs(math.e() - 2.718281828459045) < eps);
println(math.abs(math.tau() - 6.283185307179586) < eps);
println(math.is_inf(math.inf()));
println(math.is_nan(math.nan()));
println(math.is_finite(math.pi()));

println(math.abs(-9) == 9);
println(math.abs(math.abs(-1.5) - 1.5) < eps);
println(math.sign(-10) == -1);
println(math.sign(0) == 0);
println(math.sign(2.5) == 1);

println(math.min(4, 9) == 4);
println(math.max(4, 9) == 9);
println(math.clamp(12, 0, 10) == 10);
println(math.abs(math.clamp(3.2, 0.5, 2.5) - 2.5) < eps);

println(math.abs(math.floor(2.9) - 2.0) < eps);
println(math.abs(math.ceil(2.1) - 3.0) < eps);
println(math.abs(math.round(2.5) - 3.0) < eps);
println(math.abs(math.trunc(-2.9) - -2.0) < eps);
println(math.abs(math.fract(5.25) - 0.25) < eps);

println(math.abs(math.sqrt(81) - 9.0) < eps);
println(math.abs(math.cbrt(27) - 3.0) < eps);
println(math.abs(math.pow(2, 10) - 1024.0) < eps);
println(math.abs(math.hypot(3, 4) - 5.0) < eps);

println(math.abs(math.sin(0) - 0.0) < eps);
println(math.abs(math.cos(0) - 1.0) < eps);
println(math.abs(math.tan(0) - 0.0) < eps);
println(math.abs(math.asin(1) - (math.pi() / 2)) < eps);
println(math.abs(math.acos(1) - 0.0) < eps);
println(math.abs(math.atan(1) - (math.pi() / 4)) < eps);
println(math.abs(math.atan2(1, 1) - (math.pi() / 4)) < eps);

println(math.abs(math.exp(1) - math.e()) < eps);
println(math.abs(math.ln(math.e()) - 1.0) < eps);
println(math.abs(math.log2(8) - 3.0) < eps);
println(math.abs(math.log10(1000) - 3.0) < eps);
println(math.abs(math.log(8, 2) - 3.0) < eps);

println(math.abs(math.lerp(10, 20, 0.25) - 12.5) < eps);
println(math.abs(math.degrees(math.pi()) - 180.0) < eps);
println(math.abs(math.radians(180) - math.pi()) < eps);

math.seed(1337);
let r1 = math.rand_int(1, 100);
let rf1 = math.rand_float();
let rb1 = math.rand_bool();
let rr1 = math.rand_range(5, 10);

math.seed(1337);
let r2 = math.rand_int(1, 100);
let rf2 = math.rand_float();
let rb2 = math.rand_bool();
let rr2 = math.rand_range(5, 10);

println(r1 == r2);
println(math.abs(rf1 - rf2) < eps);
println(rb1 == rb2);
println(math.abs(rr1 - rr2) < eps);
println(rr1 >= 5 and rr1 < 10);
